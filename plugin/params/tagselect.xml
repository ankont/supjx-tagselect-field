<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="fieldparams">
        <fieldset name="fieldparams">
            <field
                name="multiple"
                type="radio"
                layout="joomla.form.field.radio.switcher"
                default="1"
                label="PLG_FIELDS_TAGSELECT_FIELD_MULTIPLE_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_MULTIPLE_DESC"
                filter="integer"
                validate="options"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>

            <field
                name="field_type"
                type="radio"
                layout="joomla.form.field.radio.switcher"
                default="independent"
                label="PLG_FIELDS_TAGSELECT_FIELD_TYPE_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_TYPE_DESC"
                validate="options"
            >
                <option value="independent">PLG_FIELDS_TAGSELECT_FIELD_TYPE_OPTION_INDEPENDENT</option>
                <option value="native_article_tags">PLG_FIELDS_TAGSELECT_FIELD_TYPE_OPTION_NATIVE_ARTICLE_TAGS</option>
            </field>

            <field
                name="mode"
                type="list"
                default="ajax"
                label="PLG_FIELDS_TAGSELECT_FIELD_MODE_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_MODE_DESC"
                validate="options"
            >
                <option value="ajax">PLG_FIELDS_TAGSELECT_FIELD_MODE_OPTION_AJAX</option>
                <option value="nested">PLG_FIELDS_TAGSELECT_FIELD_MODE_OPTION_NESTED</option>
            </field>

            <field
                name="tag_scope_mode"
                type="list"
                default="all"
                label="PLG_FIELDS_TAGSELECT_FIELD_TAG_SCOPE_MODE_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_TAG_SCOPE_MODE_DESC"
                validate="options"
            >
                <option value="all">PLG_FIELDS_TAGSELECT_FIELD_TAG_SCOPE_MODE_OPTION_ALL</option>
                <option value="include">PLG_FIELDS_TAGSELECT_FIELD_TAG_SCOPE_MODE_OPTION_INCLUDE</option>
                <option value="exclude">PLG_FIELDS_TAGSELECT_FIELD_TAG_SCOPE_MODE_OPTION_EXCLUDE</option>
            </field>

            <field
                name="scope_root_ids"
                type="tagselect"
                mode="ajax"
                multiple="true"
                custom="deny"
                allow_tag_creation="0"
                sync_mode_from="mode"
                sync_mode_group="fieldparams"
                showon="tag_scope_mode:include,exclude"
                label="PLG_FIELDS_TAGSELECT_FIELD_SCOPE_ROOT_IDS_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_SCOPE_ROOT_IDS_DESC"
            />

            <field
                name="include_descendants"
                type="radio"
                layout="joomla.form.field.radio.switcher"
                default="1"
                showon="field_type:independent[AND]tag_scope_mode:include"
                label="PLG_FIELDS_TAGSELECT_FIELD_INCLUDE_DESCENDANTS_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_INCLUDE_DESCENDANTS_DESC"
                filter="integer"
                validate="options"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>

            <field
                name="leaf_only"
                type="radio"
                layout="joomla.form.field.radio.switcher"
                default="0"
                label="PLG_FIELDS_TAGSELECT_FIELD_LEAF_ONLY_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_LEAF_ONLY_DESC"
                filter="integer"
                validate="options"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>

            <field
                name="allow_tag_creation"
                type="radio"
                layout="joomla.form.field.radio.switcher"
                default="0"
                label="PLG_FIELDS_TAGSELECT_FIELD_ALLOW_TAG_CREATION_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_ALLOW_TAG_CREATION_DESC"
                filter="integer"
                validate="options"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>

            <field
                name="allow_root_level_creation"
                type="radio"
                layout="joomla.form.field.radio.switcher"
                default="0"
                showon="allow_tag_creation:1"
                label="PLG_FIELDS_TAGSELECT_FIELD_ALLOW_ROOT_LEVEL_CREATION_LABEL"
                description="PLG_FIELDS_TAGSELECT_FIELD_ALLOW_ROOT_LEVEL_CREATION_DESC"
                filter="integer"
                validate="options"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
        </fieldset>
    </fields>
</form>
